{
  "name": "vehkavaraus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "devdb": "docker-compose -f compose.dev.yml up",
    "testdb": "docker-compose -f compose.test.yml up",
    "resetdb": "rm -rf ./database/ && docker-compose -f compose.dev.yml down && docker volume rm vehkavaraus_db_data",
    "enterdb": "docker exec -it vehkavaraus_db psql -U postgres",
    "entertestdb": "docker exec -it vehkavaraus_test psql -U postgres",
    "test": " vitest",
    "coverage": "vitest run --coverage",
    "migrate:dev": "tsx ./src/database/migrations/utils/migrateDev.ts",
    "migrate:prod": "tsx ./src/database/migrations/utils/migrateProd.ts",
    "migrate:dev:down": "tsx ./src/database/migrations/utils/migrateDevDown.ts",
    "migrate:prod:down": "tsx ./src/database/migrations/utils/migrateProdDown.ts",
    "migrate:test": "cross-env NODE_ENV=test tsx ./src/database/migrations/utils/migrate.ts",
    "checkTypes": "tsc --noEmit",
    "kysely": "kysely"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.4.26",
    "@react-email/components": "^0.0.28",
    "@vercel/blob": "^0.26.0",
    "bcryptjs": "^2.4.3",
    "compressorjs": "^1.2.1",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.27.6",
    "kysely-neon": "^1.3.0",
    "next": "15.0.7",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^4.8.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/env": "15.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "2.1.8",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.0.4",
    "postcss": "^8.5.8",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c",
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.1",
      "@types/react-dom": "19.0.1"
    }
  }
}
